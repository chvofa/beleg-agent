# .envrc — wird von direnv geladen, wenn man in dieses Verzeichnis cd'd.
#
# Lädt beleg-agent Secrets aus Bitwarden zur Laufzeit via `bw get`.
# KEINE Werte in dieser Datei — nur die Logic.
#
# Voraussetzung:
#   1. Bitwarden CLI installiert (brew install bitwarden-cli)
#   2. Vault entsperrt: export BW_SESSION="$(bw unlock --raw)"
#   3. Item angelegt: bw create item (siehe unten)
#
# Bitwarden-Item anlegen:
#   bw get template item | jq '.name="beleg_agent/ANTHROPIC_API_KEY" | .login.password="sk-ant-..."' | bw encode | bw create item
#
# Autorisieren: direnv allow

set -e

if ! command -v bw >/dev/null 2>&1; then
    log_error "bw (Bitwarden CLI) nicht im PATH. Install: brew install bitwarden-cli"
    return 1
fi

if [ -z "${BW_SESSION:-}" ]; then
    log_error "BW_SESSION nicht gesetzt. Vault zuerst entsperren:"
    log_error '  export BW_SESSION="$(bw unlock --raw)"'
    return 1
fi

_status=$(bw status 2>/dev/null | grep -o '"status":"[^"]*"' | sed 's/.*"\([^"]*\)"/\1/')
if [ "$_status" != "unlocked" ]; then
    log_error "Bitwarden-Vault nicht unlocked (status: $_status)"
    return 1
fi

_bw() {
    bw get password "beleg_agent/$1" --session "$BW_SESSION" 2>/dev/null
}

export ANTHROPIC_API_KEY="$(_bw ANTHROPIC_API_KEY)"

if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
    log_error "ANTHROPIC_API_KEY leer — Bitwarden-Item beleg_agent/ANTHROPIC_API_KEY fehlt oder Session abgelaufen"
fi

unset _status _bw
